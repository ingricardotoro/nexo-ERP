# === NexoERP — Variables de Entorno ===
# Copiar este archivo como .env.local para desarrollo
# DO NOT commit .env.local to Git

# ============ Database ============
# Local: Docker PostgreSQL (puerto 5433 porque 5432 está en uso por WSL)
DATABASE_URL="postgresql://nexoerp:nexoerp_dev_2026@localhost:5433/nexoerp"
DIRECT_URL="postgresql://nexoerp:nexoerp_dev_2026@localhost:5433/nexoerp"

# ============ App ============
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="NexoERP"
NEXT_PUBLIC_APP_ENV="development"
NODE_ENV="development"

# ============ AWS ============
AWS_REGION="us-east-1"

# ============ Email ============
# Local: MailHog SMTP (puerto 1025)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SES_FROM_EMAIL="no-reply@nexoerp.com"

# ============ Storage (S3) ============
S3_BUCKET_DOCUMENTS="amplify-nexoerp-marvin-sa-nexoerpdocumentsbucketb8-bimtcqkqm8s3"

# ============ Monitoring (opcional) ============
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# ============ Feature Flags ============
NEXT_PUBLIC_ENABLE_DEBUG="true"
